# CREBAIN environment configuration (examples)

# ── Models ──────────────────────────────────────────────────────────────
# macOS: compiled CoreML model directory (.mlmodelc)
# CREBAIN_MODEL_PATH=/absolute/path/to/yolov8s.mlmodelc
#
# Linux: ONNX model file (.onnx)
# CREBAIN_ONNX_MODEL=/absolute/path/to/yolov8s.onnx

# ── Backend selection (optional) ─────────────────────────────────────────
# If unset, CREBAIN auto-selects the best available backend.
# Valid values vary by platform: coreml, mlx, onnx, cuda, tensorrt
# CREBAIN_BACKEND=onnx

# ── Experimental backends ────────────────────────────────────────────────
# MLX is scaffolded and is only auto-selected when explicitly enabled.
# CREBAIN_ENABLE_EXPERIMENTAL_MLX=1
#
# MLX safetensors model path and optional SHA-256 digest pin.
# CREBAIN_MLX_MODEL=/absolute/path/to/model.safetensors
# CREBAIN_MLX_MODEL_SHA256=<64-hex-digest>
#
# Per-layer MLX latency logging.
# CREBAIN_PROFILE_MLX=1

# ── TensorRT (Linux) ─────────────────────────────────────────────────────
# Engine cache directory and cache kill-switch.
# CREBAIN_TRT_CACHE_DIR=/path/to/cache
# CREBAIN_DISABLE_TRT_CACHE=1

# ── Transport ────────────────────────────────────────────────────────────
# Enable native Zenoh transport. Only 1/true/yes/on (case-insensitive) enable
# it; any other value selects the rosbridge WebSocket fallback.
# CREBAIN_ZENOH=1
#
# rosbridge server URL used by the Rust fallback transport.
# CREBAIN_ROSBRIDGE_URL=ws://localhost:9090

# ── Galadriel evidence producer (optional; requires Cargo feature `ncp`) ───
# Runtime enable is exact: only 1 enables; absent/0 disables; other values fail.
# These placeholders are not deployment credentials or evidence.
# CREBAIN_GALADRIEL_ENABLE=0
# CREBAIN_GALADRIEL_REALM=example/ncp
# CREBAIN_GALADRIEL_PRODUCER_ID=crebain-example
# Required when enabled: operator-provisioned, key-safe 1..=64 byte session ID.
# Provision a new unique value for every process lifetime; CREBAIN checks syntax only.
# CREBAIN_GALADRIEL_EPOCH=deployment-boot-0001
# CREBAIN_GALADRIEL_REGISTRY_PATH=/absolute/path/to/deployment-registry.json
# CREBAIN_GALADRIEL_REGISTRY_DIGEST=<lowercase-canonical-registry-sha256>
# CREBAIN_GALADRIEL_FRAME_ID=1
# CREBAIN_GALADRIEL_CONTEXT_ID=1
# CREBAIN_GALADRIEL_SOFTWARE_DIGEST=<lowercase-post-package-executable-sha256>
# CREBAIN_GALADRIEL_CONFIGURATION_DIGEST=<lowercase-effective-fusion-config-sha256>
# Optional regular-local-file archive; presence enables legacy-buffer innovations
# and changes the effective configuration digest. An ncp build preflights it.
# Never use a FIFO/device/socket/remote mount.
# CREBAIN_PID_JSONL=/absolute/local/path/to/crebain-pid.jsonl
# Optional: strict, bounded FusionConfig JSON; absence selects the Rust default.
# CREBAIN_GALADRIEL_FUSION_CONFIG_PATH=/absolute/path/to/fusion-config.json
# CREBAIN_GALADRIEL_HEARTBEAT_INTERVAL_MS=1000
# CREBAIN_GALADRIEL_HEARTBEAT_DEADLINE_MS=3000
# Queue defaults come from the pinned registry and must fit its aggregate cap.
# CREBAIN_GALADRIEL_OBSERVATION_QUEUE_CAPACITY=256
# CREBAIN_GALADRIEL_OUTCOME_QUEUE_CAPACITY=256
# CREBAIN_GALADRIEL_SUMMARY_QUEUE_CAPACITY=64
# CREBAIN_GALADRIEL_HEARTBEAT_QUEUE_CAPACITY=16
# Secure-mode NCP Zenoh configuration. Loading it is not TLS/identity/ACL proof.
# NCP_ZENOH_CONFIG=/absolute/path/to/ncp-zenoh.json5

# ── Logging ─────────────────────────────────────────────────────────────
# RUST_LOG=info

# CREBAIN environment configuration (examples)

# ── Models ──────────────────────────────────────────────────────────────
# macOS: compiled CoreML model directory (.mlmodelc)
# CREBAIN_MODEL_PATH=/absolute/path/to/yolov8s.mlmodelc
#
# Linux: ONNX model file (.onnx)
# CREBAIN_ONNX_MODEL=/absolute/path/to/yolov8s.onnx

# ── Backend selection (optional) ─────────────────────────────────────────
# If unset, CREBAIN auto-selects the best available backend.
# Valid values vary by platform: coreml, mlx, onnx, cuda, tensorrt
# CREBAIN_BACKEND=onnx

# ── Experimental backends ────────────────────────────────────────────────
# MLX is scaffolded and is only auto-selected when explicitly enabled.
# CREBAIN_ENABLE_EXPERIMENTAL_MLX=1
#
# MLX safetensors model path and optional SHA-256 digest pin.
# CREBAIN_MLX_MODEL=/absolute/path/to/model.safetensors
# CREBAIN_MLX_MODEL_SHA256=<64-hex-digest>
#
# Per-layer MLX latency logging.
# CREBAIN_PROFILE_MLX=1

# ── TensorRT (Linux) ─────────────────────────────────────────────────────
# Engine cache directory and cache kill-switch.
# CREBAIN_TRT_CACHE_DIR=/path/to/cache
# CREBAIN_DISABLE_TRT_CACHE=1

# ── Transport ────────────────────────────────────────────────────────────
# Enable native Zenoh transport. Only 1/true/yes/on (case-insensitive) enable
# it; any other value selects the rosbridge WebSocket fallback.
# CREBAIN_ZENOH=1
#
# rosbridge server URL used by the Rust fallback transport.
# CREBAIN_ROSBRIDGE_URL=ws://localhost:9090

# ── Logging ─────────────────────────────────────────────────────────────
# RUST_LOG=info

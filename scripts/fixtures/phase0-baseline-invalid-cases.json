      "mutation": {
        "type": "remove-configuration-artifact",
        "document": "ecosystem",
        "value": "scripts/lib/production-vendor-boundary.mjs"
      },
      "expected_error": "production boundary artifact is not digest-pinned"
    },
    {
      "id": "misleading-profile-semantics",

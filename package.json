{
  "name": "crebain",
  "version": "0.4.0",
  "description": "Adaptive Response & Awareness System - research-oriented tactical visualization prototype",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/sepahead/crebain.git"
  },
  "homepage": "https://github.com/sepahead/crebain#readme",
  "bugs": {
    "url": "https://github.com/sepahead/crebain/issues"
  },
  "keywords": [
    "drone-detection",
    "sensor-fusion",
    "tauri",
    "ros2",
    "gaussian-splatting",
    "coreml",
    "cuda",
    "computer-vision",
    "surveillance"
  ],
  "author": "CREBAIN Contributors",
  "engines": {
    "node": ">=20.19.0",
    "bun": ">=1.3.14"
  },
  "scripts": {
    "dev": "bunx --bun vite",
    "build": "bun run typecheck && bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "check:bundle": "bun run build && node scripts/check-bundle-size.mjs",
    "perf:smoke": "node scripts/perf-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bunx --bun vitest",
    "test:run": "bunx --bun vitest run",
    "test:ui": "bunx --bun vitest --ui",
    "test:benchmark": "RUN_BENCHMARKS=1 bunx --bun vitest run --reporter=verbose src/detection/__tests__/DetectorBenchmark.test.ts",
    "test:coverage": "bunx --bun vitest run --coverage",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "clippy:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "check:rust:ncp": "cargo check --manifest-path src-tauri/Cargo.toml --features ncp",
    "clippy:rust:ncp": "cargo clippy --manifest-path src-tauri/Cargo.toml --features ncp --all-targets -- -D warnings",
    "test:rust:ncp": "cargo test --manifest-path src-tauri/Cargo.toml --features ncp",
    "fmt:rust": "cargo fmt --manifest-path src-tauri/Cargo.toml",
    "fmt:rust:check": "cargo fmt --manifest-path src-tauri/Cargo.toml --check",
    "validate": "bun run typecheck && bun run lint && bun run format:check && bun run test:run",
    "validate:all": "bun run validate && bun run fmt:rust:check && bun run check:rust && bun run test:rust && bun run clippy:rust && bun run clippy:rust:ncp && bun run test:rust:ncp",
    "tauri": "bunx tauri",
    "tauri:dev": "bunx tauri dev",
    "tauri:build": "bunx tauri build",
    "clean": "rm -rf dist node_modules/.vite src-tauri/target"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@sepahead/ncp": "github:sepahead/NCP#v0.7.0",
    "@sparkjsdev/spark": "^0.1.10",
    "comlink": "^4.4.2",
    "onnxruntime-web": "^1.27.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-istanbul": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "postcss": "^8.5.16",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "@protobufjs/utf8": "1.1.2",
    "flatted": "3.4.2",
    "picomatch": "4.0.5",
    "protobufjs": "7.6.5",
    "rollup": "4.62.2"
  }
}
